{
  "name": "script-editor-standalone",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx concurrently -c \"bgBlue.bold,bgMagenta.bold\" \"npm:backend\" \"npm:frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
