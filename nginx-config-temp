server {
    server_name lipistudio.me www.lipistudio.me;

    location / {
        root /home/ubuntu/script-editor/frontend/dist;
        try_files $uri $uri/ /index.html;
    }

    location /api {
        proxy_pass http://localhost:5003;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # Disable buffering, cache, and gzip compression for real-time streaming
        proxy_buffering off;
        proxy_cache off;
        gzip off;
        proxy_max_temp_file_size 0;
        
        # Long timeouts for streaming reasoning tools
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/lipistudio.me/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/lipistudio.me/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.lipistudio.me) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = lipistudio.me) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name lipistudio.me www.lipistudio.me;
    return 404; # managed by Certbot
}
